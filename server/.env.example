PORT=5000

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_postgres_password
DB_NAME=patch_patrol
DB_POOL_MAX=10

# 32-byte base64 value or a 64-character hex string.
ENCRYPTION_KEY=replace_with_a_32_byte_base64_or_hex_key

# Shared secret configured in the GitHub webhook settings.
WEBHOOK_SECRET=replace_with_your_github_webhook_secret

# Optional: protects repo registration and manual scan endpoints.
APP_API_TOKEN=replace_with_an_internal_api_token

#AI prototype
AI_ENABLED=true
AI_PROVIDER=openrouter
OPENROUTER_API_KEY=replace_with_your_openrouter_api_key
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-small
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1/chat/completions
OPENROUTER_SITE_URL=http://localhost:5000
OPENROUTER_APP_NAME=Patch Patrol
AI_VECTOR_STORE=pgvector-planned
AI_MAX_MODEL_EXPLANATIONS_PER_SCAN=10

SLACK_WEBHOOK_URL=replace_with_your_slack_webhook_url